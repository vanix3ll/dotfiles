      "interval": 5,
      "format": "{}",
      "tooltip": "CPU Governor and Frequency"
  }
  
  },

  "tray": {
    "spacing": 10
  },

  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M %p}",
    "format-alt": "{:%Y-%m-%d}"
