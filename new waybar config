{
  "layer": "top",
  "position": "bottom",
  "height": 30,
  "spacing": 4,

  "modules-left": ["hyprland/workspaces", "hyprland/mode"],
  "modules-center": ["clock","custom/cpu"],
  "modules-right": [
    "network",
    "pulseaudio",
    "tray"
  ],

  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "пЂЈ",
      "unlocked": "п‚њ"
    }
