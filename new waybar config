{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 2,

  "modules-left": [
    "sway/workspaces"
  ],

  "modules-center": [
    "sway/window"
  ],

  "modules-right": [
    "cpu",
    "memory",
    "pulseaudio",
    "network",
    "clock"
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "focused": "●",
      "default": "○"
    }
  },

  "sway/window": {
    "format": "{}",
    "max-length": 60
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {}%"
  },

  "network": {
    "format-wifi": "WiFi",
    "format-ethernet": "ETH",
    "format-disconnected": "No Net"
  },

"pulseaudio": {
  "format": "VOL {volume}%",
  "format-muted": "MUTED",
  "on-click": "pavucontrol"
},

  "battery": {
    "format": "BAT {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    }
  }
}
