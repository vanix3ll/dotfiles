# Import colors from pywal
include ~/.cache/wal/colors-sway

# Border colors using pywal variables
# class                 border      background  text        indicator   child_border
client.focused          $color4     $color4     $foreground $color5     $color4
client.focused_inactive $color1     $color1     $foreground $color3     $color1
client.unfocused        $background $background $foreground $color1     $background
client.urgent           $color9     $color9     $foreground $color9     $color9
client.placeholder      $background $background $foreground $background $background
client.background       $background

# Environment setup
# Add this to your sway config
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
# Reduce input latency
input * {
    accel_profile flat
    pointer_accel 0
}

exec_always --no-startup-id autotiling
exec_always swww-daemon &
exec_always waybar
exec wl-clip-persist --clipboard regular --daemon
exec wl-paste -t text --watch clipman store --histpath ~/.local/share/clipman.json

focus_follows_mouse always

# Keyboard setup
input "9610:73:BY_Tech_Gaming_Keyboard" {
    repeat_delay 200
    repeat_rate 50
    xkb_layout us
}

input "1:1:AT_Translated_Set_2_keyboard" {
    repeat_delay 200
    repeat_rate 50
    xkb_layout us
}

# # Logitech G102 Mouse Settings
input "1133:49309:Logitech_G102_LIGHTSYNC_Gaming_Mouse" {
    middle_emulation enabled
    scroll_method on_button_down
    scroll_button BTN_MIDDLE
}

# Touchpad Settings (Enabling Tap-to-click and Middle Emulation)
input "1267:12608:ELAN06FA:00_04F3:3140_Touchpad" {
    tap enabled
    middle_emulation enabled
    natural_scroll enabled
}

# Monitor 
output eDP-1 mode 1920x1080@60Hz scale 1.2

# Fonts
font pango:Noto Sans, Noto Naskh Arabic 10

default_border pixel 2
default_floating_border pixel 2
titlebar_border_thickness 0
mouse_warping none

# Mod key and variables
set $mod Mod4
set $left h
set $down i
set $up u
set $right w
set $resize_factor 40px
set $menu rofi -show drun | swaymsg
set $file rofi -show filebrowser | swaymsg
set $power rofi -show powermenu | swaymsg
set $browser flatpak run org.chromium.Chromium
set $private-browser firefox --private-window
set $term alacritty

# Borders and gaps
gaps outer 5
gaps inner 5
smart_borders off

# Input behavior
input type:touchpad {
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    dwt disabled
}

input type:keyboard {
    xkb_options ctrl:nocaps
}

input type:touch {
    events disabled
}

# Load Xresources
exec_always xrdb -load ~/.Xresources

# Keybindings
bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec $menu
bindsym $mod+b exec $browser
bindsym $mod+Shift+b exec $private-browser
bindsym $mod+Tab workspace next
bindsym $mod+e exec $file
bindsym $mod+z exec pavucontrol
bindsym $mod+Shift+c reload
bindsym $mod+r exec killall waybar && waybar
bindsym $mod+v exec clipman pick -t rofi

# Multimedia keys
bindsym --locked XF86MonBrightnessUp exec light -A 5
bindsym --locked XF86MonBrightnessDown exec light -U 5
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPrev exec playerctl previous
bindsym $mod+p exec playerctl play-pause
bindsym $mod+Shift+m exec playerctl next
bindsym $mod+Shift+n exec playerctl previous

# Floating modifier
floating_modifier $mod normal

# Movement
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym Alt+Tab focus right
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Ctrl+$left resize shrink width $resize_factor
bindsym $mod+Ctrl+$down resize grow height $resize_factor
bindsym $mod+Ctrl+$up resize shrink height $resize_factor
bindsym $mod+Ctrl+$right resize grow width $resize_factor

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Layout & window controls
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Screenshot
bindsym --release $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy

# Window assignments
assign [app_id="spotify"] workspace number 3
assign [app_id="org.chromium.Chromium"] workspace number 1
assign [app_id="org.vinegarhq.sober"] workspace number 4
assign [app_id="vesktop"] workspace number 2

# Tearing support
output * allow_tearing enabled
for_window [app_id="gamemode"] allow_tearing enabled

workspace_auto_back_and_forth yes
