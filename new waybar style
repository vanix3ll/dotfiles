@import "../../.cache/wal/colors-waybar.css";

* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 14px;
    min-height: 0;
}

window#waybar {
    background: @background;
    color: @foreground;
}

/* Workspaces */
#workspaces button {
    padding: 0 8px;
    background: @color0;
    color: @foreground;
}

#workspaces button.active {
    background: @color1;
    color: @background;
}

#workspaces button.urgent {
    background: @color9;
}

#workspaces button:hover {
    background: @color8;
}

/* Modules */
#clock,
#battery,
#cpu,
#memory,
#network,
#pulseaudio,
#tray,
#mode,
#custom-media {
    padding: 0 10px;
    margin: 0 2px;
    background: @color0;
    color: @foreground;
}

#battery.charging {
    color: @color2;
}

#battery.warning:not(.charging) {
    color: @color3;
}

#battery.critical:not(.charging) {
    color: @color1;
}

#network.disconnected {
    color: @color8;
}

#pulseaudio.muted {
    color: @color8;
}
