* {
    border: none;
    font-family: "monospace";
    font-size: 14px;
}

window#waybar {
    background: #1a1a1a;
    color: #ffffff;
    /* Adding radius and margin for the floating look */
    border-radius: 15px; 
    margin: 10px 10px 0 10px; 
}

/* Optional: This creates a wrapper for the modules inside the bar */
.modules-left, .modules-center, .modules-right {
    background: #252525;
    border-radius: 12px;
    margin: 4px;
    padding: 0 5px;
}

#workspaces button {
    padding: 0 8px;
    background: transparent;
    color: #ffffff;
    border-radius: 10px; /* Rounded workspace buttons */
}

#workspaces button.focused {
    background: #323223;
    border-radius: 10px;
}

#clock, #pulseaudio, #network, #tray {
    padding: 0 10px;
    margin: 2px 0;
}

/* Optional: Slight color coding */
#network { color: #88c0d0; }
#pulseaudio { color: #ebcb8b; }
#pulseaudio.microphone { color: #d08770; }
